    "@oxc-project/runtime": "^0.115.0",
    "@schematics/angular": "21.2.9",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.23",
    "@types/express": "^5.0.3",
