    "stripe": "^22.2.0",
    "tailwindcss": "^4.1.14",
    "tailwindcss-primeui": "^0.6.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.1.3",
