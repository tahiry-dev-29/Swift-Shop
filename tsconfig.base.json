{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "importHelpers": true,
    "ignoreDeprecations": "6.0",
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@swift-shop/models": ["models/src/index.ts"],
      "@swift-shop/ui": ["shared/ui/src/index.ts"],
      "@swift-shop/data-access-prisma": [
        "libs/data-access-prisma/src/index.ts"
      ],
      "@swift-shop/backend/auth": ["libs/backend/core/auth/src/index.ts"],
      "@swift-shop/backend/customer": [
        "libs/backend/features/customer/src/index.ts"
      ],
      "@swift-shop/backend/employee": [
        "libs/backend/features/employee/src/index.ts"
      ],
      "@swift-shop/backend/customer-group": [
        "libs/backend/features/customer-group/src/index.ts"
      ],
      "@swift-shop/backend/address": [
        "libs/backend/features/address/src/index.ts"
      ],
      "@swift-shop/backend/catalog": [
        "libs/backend/features/catalog/src/index.ts"
      ],
      "@swift-shop/backend/pricing": [
        "libs/backend/features/pricing/src/index.ts"
      ],
      "@swift-shop/backend/cart": ["libs/backend/features/cart/src/index.ts"],
