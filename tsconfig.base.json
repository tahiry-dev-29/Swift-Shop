      "@spartan-ng/helm/alert": ["./libs/ui/alert/src/index.ts"],
      "@spartan-ng/helm/sonner": ["./libs/ui/sonner/src/index.ts"],
      "@spartan-ng/helm/skeleton": ["./libs/ui/skeleton/src/index.ts"],
      "@spartan-ng/helm/progress": ["./libs/ui/progress/src/index.ts"],
      "@spartan-ng/helm/spinner": ["./libs/ui/spinner/src/index.ts"],
