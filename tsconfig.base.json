{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@dima-new/models": ["models/src/index.ts"],
      "@dima-new/ui": ["shared/ui/src/index.ts"],
      "@dima-new/data-access-prisma": ["libs/data-access-prisma/src/index.ts"],
      "@dima-new/backend/auth": ["libs/backend/core/auth/src/index.ts"],
      "@dima-new/backend/customer": [
        "libs/backend/features/customer/src/index.ts"
      ],
      "@dima-new/backend/employee": [
        "libs/backend/features/employee/src/index.ts"
      ],
      "@dima-new/backend/customer-group": [
        "libs/backend/features/customer-group/src/index.ts"
      ],
      "@dima-new/backend/address": [
        "libs/backend/features/address/src/index.ts"
      ],
      "@dima-new/backend/catalog": [
        "libs/backend/features/catalog/src/index.ts"
      ],
      "@dima-new/backend/pricing": [
        "libs/backend/features/pricing/src/index.ts"
      ],
      "@dima-new/backend/cart": ["libs/backend/features/cart/src/index.ts"],
      "@dima-new/backend/order": ["libs/backend/features/order/src/index.ts"],
      "@dima-new/backend/shipping": [
        "libs/backend/features/shipping/src/index.ts"
      ],
      "@dima-new/backend/payment": [
        "libs/backend/features/payment/src/index.ts"
      ],
      "@dima-new/backend/analytics": [
        "libs/backend/features/analytics/src/index.ts"
      ],
      "@dima-new/backend/search": ["libs/backend/core/search/src/index.ts"],
      "meilisearch": ["node_modules/meilisearch/dist/index.d.ts"],
      "@dima-new/prisma-client": ["prisma/generated/client/client.ts"],
      "@dima-new/backend/media": ["./libs/backend/core/media/src/index.ts"],
      "@dima-new/backend/settings": [
        "./libs/backend/features/settings/src/index.ts"
      ],
      "@backend/features/support": [
        "./libs/backend/features/support/src/index.ts"
      "@dima-new/backend/notifications": [
        "./libs/backend/features/notifications/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
