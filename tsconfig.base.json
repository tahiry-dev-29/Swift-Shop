      "@swift-shop/backend/shipping": [
        "libs/backend/features/shipping/src/index.ts"
      ],
      "@swift-shop/backend/payment": [
        "libs/backend/features/payment/src/index.ts"
      ],
      "@swift-shop/backend/analytics": [
        "libs/backend/features/analytics/src/index.ts"
      ],
      "@swift-shop/backend/search": ["libs/backend/core/search/src/index.ts"],
      "meilisearch": ["node_modules/meilisearch/dist/index.d.ts"],
      "@swift-shop/prisma-client": ["prisma/generated-client/client.ts"],
      "@swift-shop/prisma-client/*": ["prisma/generated-client/*"],
      "@swift-shop/backend/media": ["./libs/backend/core/media/src/index.ts"],
      "@swift-shop/backend/settings": [
        "./libs/backend/features/settings/src/index.ts"
