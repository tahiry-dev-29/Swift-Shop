{
  "name": "command",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ui/command/src",
  "prefix": "hlm",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "defaultConfiguration": "production",
      "options": {
        "project": "libs/ui/command/ng-package.json",
        "tsConfig": "libs/ui/command/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/ui/command/tsconfig.lib.prod.json"
        },
        "development": {}
      }
    },
    "lint": {
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/eslint.config.mjs",
        "{workspaceRoot}/tools/eslint-rules/**/*",
        {
          "externalDependencies": ["eslint"]
        }
      ]
    }
  }
}
