// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------
// ROLES (Employee Permissions)
// ----------------------------------------------------------------------

model Role {
  id          String     @id @default(uuid())
  name        String     @unique // SUPER_ADMIN, ADMIN, etc.
  description String?
  isSystem    Boolean    @default(false) // If true, cannot be deleted/renamed

  employees   Employee[]
}


// ----------------------------------------------------------------------
// CUSTOMERS (Front-Office Auth)
// ----------------------------------------------------------------------

model Customer {
  id              String    @id @default(uuid())
  
  // Auth Info
  email           String    @unique
  password        String    // Hashed (Argon2)
  
  // Personal Info
  firstname       String
  lastname        String
  birthday        DateTime?
  company         String?
  siret           String?
  ape             String?
  
  // Status & Logic
  active          Boolean   @default(true)
  isGuest         Boolean   @default(false)
  optin           Boolean   @default(false)
  dateAdd         DateTime  @default(now())
  dateUpd         DateTime  @updatedAt
  
  // Relations
  groupId         String
  group           CustomerGroup @relation(fields: [groupId], references: [id])
  
  countryId       String?      // Pays du client pour le calcul de la TVA
  country         Country?  @relation(fields: [countryId], references: [id])
  
  addresses       Address[]
  orders          Order[]
  specificPrices  SpecificPrice[]
}

model CustomerGroup {
  id            String     @id @default(uuid())
  name          String
  reduction     Decimal    @default(0.00)
  showPrices    Boolean    @default(true)
  
  customers      Customer[]
  specificPrices SpecificPrice[]
}

// ----------------------------------------------------------------------
// EMPLOYEES (Back-Office Auth)
// ----------------------------------------------------------------------

model Employee {
  id            String   @id @default(uuid())
  
  // Auth Info
  email         String   @unique
  password      String   // Hashed (Argon2)
  
  // Personal Info
  firstname     String
  lastname      String
  
  // Permissions & Access
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id])
  
  active        Boolean  @default(true)
  lastConnectionDate DateTime?
  dateAdd       DateTime @default(now())
  dateUpd       DateTime @updatedAt
}

// ----------------------------------------------------------------------
// ADDRESSES
// ----------------------------------------------------------------------

model Address {
  id              String   @id @default(uuid())
  customerId      String?
  alias           String
  company         String?
  lastname        String
  firstname       String
  address1        String
  address2        String?
  postcode        String
  city            String
  countryId       String
  phone           String?
  phoneMobile     String?
  vatNumber       String?
  
  active          Boolean  @default(true)
  deleted         Boolean  @default(false)

  // Relations
  customer        Customer? @relation(fields: [customerId], references: [id])
  country         Country   @relation(fields: [countryId], references: [id])
}

// ----------------------------------------------------------------------
// CATALOG - CATEGORIES (Tree Structure)
// ----------------------------------------------------------------------

model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  active      Boolean    @default(true)
  position    Int        @default(0)
  
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  
  products    Product[]
  
  dateAdd     DateTime   @default(now())
  dateUpd     DateTime   @updatedAt
}

// ----------------------------------------------------------------------
// CATALOG - ATTRIBUTES (Product Variants like Size, Color)
// ----------------------------------------------------------------------

model AttributeGroup {
  id          String           @id @default(uuid())
  name        String           @unique  // Internal name (e.g. "Size")
  publicName  String           // Customer facing name (e.g. "Taille")
  position    Int              @default(0)
  type        String           @default("select") // select, radio, color
  
  values      AttributeValue[]
}

model AttributeValue {
  id              String         @id @default(uuid())
  attributeGroupId String
  name            String         // e.g. "S", "Red"
  color           String?        // For color type attributes
  position        Int            @default(0)
  
  group           AttributeGroup @relation(fields: [attributeGroupId], references: [id], onDelete: Cascade)
  combinationAttributes ProductCombinationAttribute[]
  
  @@unique([attributeGroupId, name])
}

// ----------------------------------------------------------------------
// PRODUCTS CORE
// ----------------------------------------------------------------------

model Product {
  id               String    @id @default(uuid())
  reference        String    @unique  // SKU (ex: "TSHIRT-001")
  
  // Basic Info
  name             String
  description      String?
  descriptionShort String?
  
  // Pricing (base price HT)
  price            Decimal   @default(0.00)
  wholesalePrice   Decimal   @default(0.00)  // Prix d'achat
  
  // Status & Visibility
  active           Boolean   @default(true)
  availableForOrder Boolean  @default(true)
  showPrice        Boolean   @default(true)
  
  // SEO
  metaTitle        String?
  metaDescription  String?
  linkRewrite      String?   // URL slug
  
  // Physical
  weight           Decimal   @default(0.00)
  width            Decimal?
  height           Decimal?
  depth            Decimal?
  
  // Relations
  categoryId       String?
  category         Category? @relation(fields: [categoryId], references: [id])
  
  images           ProductImage[]
  combinations     ProductCombination[]
  stock            Stock?     // For products without combinations
  specificPrices   SpecificPrice[]
  
  dateAdd          DateTime  @default(now())
  dateUpd          DateTime  @updatedAt
}

model ProductImage {
  id          String   @id @default(uuid())
  productId   String
  position    Int      @default(0)
  cover       Boolean  @default(false)  // Image principale
  
  // Image stored: uploads/products/{productId}/{originalName}_{date}_{randomId}.{ext}
  filename    String   // e.g. "tshirt-blue_20251209_abc123.jpg"
  originalName String  // Original uploaded filename
  path        String   // Full path: "uploads/products/1/tshirt-blue_20251209_abc123.jpg"
  mimeType    String   // e.g. "image/jpeg"
  size        Int      // File size in bytes
  alt         String?
  
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  dateAdd     DateTime @default(now())
}

model ProductCombination {
  id              String    @id @default(uuid())
  productId       String
  reference       String?   // Ref spécifique combinaison
  
  // Price Impact
  priceImpact     Decimal   @default(0.00)  // +/- sur le prix de base
  weightImpact    Decimal   @default(0.00)
  
  // Status
  active          Boolean   @default(true)
  isDefault       Boolean   @default(false)
  
  // Relations
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributes      ProductCombinationAttribute[]
  stock           Stock?
  specificPrices  SpecificPrice[]
}

model ProductCombinationAttribute {
  id               String             @id @default(uuid())
  combinationId    String
  attributeValueId String
  
  combination      ProductCombination @relation(fields: [combinationId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue     @relation(fields: [attributeValueId], references: [id])
  
  @@unique([combinationId, attributeValueId])
}

model Stock {
  id                  String    @id @default(uuid())
  
  // Peut être lié à un produit OU une combinaison
  productId           String?      @unique
  combinationId       String?      @unique
  
  quantity            Int       @default(0)
  minQuantity         Int       @default(1)   // Alerte stock bas
  outOfStockBehavior  String    @default("deny") // deny, allow, default
  
  product             Product?           @relation(fields: [productId], references: [id], onDelete: Cascade)
  combination         ProductCombination? @relation(fields: [combinationId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------
// PLACEHOLDER MODELS (For Relations)
// ----------------------------------------------------------------------

model Order {
  id          String   @id @default(uuid())
  customerId  String
  reference   String   @unique
  totalPaid   Decimal  @default(0.00)
  dateAdd     DateTime @default(now())
  
  customer    Customer @relation(fields: [customerId], references: [id])
}


// ----------------------------------------------------------------------
// PRICING ENGINE
// ----------------------------------------------------------------------

// Country (pour les taxes et adresses)
model Country {
  id          String   @id @default(uuid())
  isoCode     String   @unique  // FR, US, DE, etc.
  name        String
  active      Boolean  @default(true)
  
  // Tax configuration
  taxRate     Decimal  @default(20.00)  // TVA par défaut (ex: 20% pour FR)
  
  customers   Customer[]
  addresses   Address[]
  taxRules    TaxRule[]
  specificPrices SpecificPrice[]
}

// Tax Rules (Règles de TVA avancées)
model TaxRule {
  id          String   @id @default(uuid())
  name        String   // Ex: "TVA FR Standard"
  countryId   String
  rate        Decimal  // 20.00 pour 20%
  active      Boolean  @default(true)
  
  country     Country  @relation(fields: [countryId], references: [id])
}

// Specific Prices (Prix spécifiques / Promotions)
model SpecificPrice {
  id              String    @id @default(uuid())
  
  // Cibles (au moins une doit être définie)
  productId       String?
  combinationId   String?
  customerId      String?
  customerGroupId String?
  countryId       String?
  
  // Réduction
  reductionType   String    // "percentage" ou "amount"
  reduction       Decimal   // 10.00 pour 10% ou 10€
  
  // Conditions
  fromQuantity    Int       @default(1)  // À partir de X unités
  dateFrom        DateTime?
  dateTo          DateTime?
  
  // Priorité (plus haut = prioritaire)
  priority        Int       @default(1)
  
  active          Boolean   @default(true)
  dateAdd         DateTime  @default(now())
  
  // Relations
  product         Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  combination     ProductCombination? @relation(fields: [combinationId], references: [id], onDelete: Cascade)
  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerGroup   CustomerGroup?   @relation(fields: [customerGroupId], references: [id])
  country         Country?         @relation(fields: [countryId], references: [id])
}
